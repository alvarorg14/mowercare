# Spring Boot API (copy to .env locally; never commit secrets)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# One-time / operator bootstrap: POST /api/v1/bootstrap/organization with header X-Bootstrap-Token
MOWERCARE_BOOTSTRAP_TOKEN=

# JWT access tokens (HS256) — secret must be at least 32 UTF-8 bytes
MOWERCARE_JWT_SECRET=
MOWERCARE_JWT_ISSUER=
MOWERCARE_JWT_ACCESS_TTL=
MOWERCARE_JWT_REFRESH_TTL=

# Expo mobile — public API origin for dev (optional; app defaults to http://localhost:8080)
EXPO_PUBLIC_API_BASE_URL=

# Maestro E2E (names only — never commit real secrets; see docs/testing-e2e.md)
# E2E_APP_ID=
# E2E_API_URL=
# E2E_BOOTSTRAP_TOKEN=
# E2E_ORG_ID=
# E2E_ORG_NAME=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=
# E2E_ISSUE_TITLE=

# Firebase Cloud Messaging (optional — push is skipped when disabled or unset)
# MOWERCARE_FIREBASE_ENABLED=true
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/firebase-adminsdk.json
